{
  "name": "@solvrae/core",
  "version": "0.1.0",
  "description": "Framework-agnostic engine for Solvrae: context, package-manager, plan/execute, registry schemas, and the adapter contract",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "semver": "^7.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@solvrae/config": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/semver": "^7.5.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "Febri Ardiansyah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solvrae/solvrae.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/solvrae/solvrae#readme",
  "bugs": "https://github.com/solvrae/solvrae/issues",
  "keywords": [
    "solvrae",
    "turborepo",
    "monorepo",
    "shadcn",
    "shadcn-ui",
    "tailwindcss",
    "scaffolding",
    "cli",
    "engine"
  ],
  "publishConfig": {
    "access": "public"
  }
}
