{
  "name": "solvrae",
  "version": "0.1.0",
  "description": "The Solvrae CLI — add frameworks and inspect a cross-framework Turborepo",
  "license": "MIT",
  "type": "module",
  "bin": {
    "solvrae": "./dist/bin.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@solvrae/core": "workspace:*",
    "@solvrae/scaffold": "workspace:*",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@solvrae/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "Febri Ardiansyah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solvrae/solvrae.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/solvrae/solvrae#readme",
  "bugs": "https://github.com/solvrae/solvrae/issues",
  "keywords": [
    "solvrae",
    "turborepo",
    "monorepo",
    "shadcn",
    "shadcn-ui",
    "tailwindcss",
    "scaffolding",
    "cli",
    "react",
    "vue",
    "svelte"
  ],
  "publishConfig": {
    "access": "public"
  }
}
