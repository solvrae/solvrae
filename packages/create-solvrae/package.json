{
  "name": "create-solvrae",
  "version": "0.0.0",
  "description": "Scaffold a cross-framework Turborepo with shadcn/ui, wired by Solvrae",
  "license": "MIT",
  "type": "module",
  "bin": {
    "create-solvrae": "./dist/bin.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@solvrae/adapter-next": "workspace:*",
    "@solvrae/core": "workspace:*",
    "@solvrae/ui-templates": "workspace:*",
    "commander": "^13.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@solvrae/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
