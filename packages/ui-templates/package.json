{
  "name": "@solvrae/ui-templates",
  "version": "0.0.0",
  "description": "UI package templates for Solvrae: the shared theme and per-family shadcn UI packages",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@solvrae/core": "workspace:*"
  },
  "devDependencies": {
    "@solvrae/config": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "author": "Febri Ardiansyah",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solvrae/solvrae.git",
    "directory": "packages/ui-templates"
  },
  "homepage": "https://github.com/solvrae/solvrae#readme",
  "bugs": "https://github.com/solvrae/solvrae/issues",
  "keywords": [
    "solvrae",
    "turborepo",
    "monorepo",
    "shadcn",
    "shadcn-ui",
    "tailwindcss",
    "scaffolding",
    "cli",
    "ui",
    "components",
    "react",
    "vue",
    "svelte"
  ],
  "publishConfig": {
    "access": "public"
  }
}
